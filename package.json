{
  "name": "nxs1",
  "version": "1.0.0",
  "scripts": {
    "build": "cd frontend && npm run build && mv ../src/public/browser/* ../src/public/ && rm -rf ../src/public/browser",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "tsc && wrangler deploy --dry-run",
    "predeploy": "wrangler d1 migrations apply DB --remote",
    "seedLocalD1": "wrangler d1 migrations apply DB --local"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "sass": "^1.72.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.0.0",
    "@cloudflare/workers-types": "^4.20240312.0"
  }
}
