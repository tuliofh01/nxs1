{
  "name": "nxs1",
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:css": "sass src/public/scss/styles.scss src/public/css/styles.css --no-source-map",
    "watch:css": "sass --watch src/public/scss/styles.scss:src/public/css/styles.css",
    "cf-typegen": "wrangler types",
    "check": "tsc && wrangler deploy --dry-run",
    "predeploy": "wrangler d1 migrations apply DB --remote",
    "seedLocalD1": "wrangler d1 migrations apply DB --local"
  },
  "devDependencies": {
    "sass": "^1.72.0",
    "typescript": "^5.9.3",
    "wrangler": "^3.0.0",
    "@cloudflare/workers-types": "^4.20240312.0"
  }
}
